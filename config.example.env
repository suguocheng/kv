# KV系统配置文件 - 示例
# 复制为 config.env 并根据需要修改

# 服务器配置
SERVER_PORT_0=9000
SERVER_PORT_1=9001
SERVER_PORT_2=9002

# WAL配置
SERVER_MAX_WAL_ENTRIES=500  # 减少WAL条目数，提高写入性能
SERVER_SNAPSHOT_INTERVAL=500  # 减少快照间隔，提高恢复性能

# 客户端配置
CLIENT_TIMEOUT=5s
CLIENT_RETRY_ATTEMPTS=3

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=log/kv.log

# 性能配置
MAX_CONCURRENT_REQUESTS=1000
REQUEST_TIMEOUT=30s

 